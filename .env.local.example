# MBG Soe Supply Chain · Environment Variables · EXAMPLE
# Copy file ini ke `.env.local` dan isi nilai-nilainya dari Supabase Dashboard.
# `.env.local` sudah di-ignore oleh .gitignore — JANGAN commit file dengan isi asli.

# ---- Supabase (wajib) ------------------------------------------------------
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Publishable (anon) key — respects RLS. Aman untuk client & browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# Service role key — BYPASS RLS. Hanya server (admin routes, seed, RLS tests).
# JANGAN expose ke client. Di Vercel, mark sebagai "Sensitive".
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# ---- App ------------------------------------------------------------------
# Base URL aplikasi. Dipakai magic-link redirect + OpenGraph.
# Local:   http://localhost:3000
# Prod:    https://mbg-soe.vercel.app  (atau domain custom)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Optional -------------------------------------------------------------
# Sentry DSN (error reporting). Kosongkan untuk disable.
# NEXT_PUBLIC_SENTRY_DSN=

# DB password (dipakai script DDL di supabase/_apply-*.js). Local only.
# SUPABASE_DB_PASSWORD=

# Dev-only admin bypass (login shortcut /api/dev-login). SET "1" only locally.
# DEV_ADMIN=0
