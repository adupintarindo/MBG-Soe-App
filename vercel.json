{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "next build",
  "regions": ["sin1"],
  "env": {
    "NEXT_PUBLIC_SITE_URL": "https://mbg-soe.vercel.app"
  },
  "crons": [
    {
      "path": "/api/cron/maintenance",
      "schedule": "0 17 * * *"
    }
  ]
}
